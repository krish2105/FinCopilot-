# ==========================================================================
# FinCopilot — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All services below have a free tier; no paid keys are required for the MVP.
# ==========================================================================

# --- LLM providers (free tiers) ---
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Groq Cloud: https://console.groq.com/keys
GROQ_API_KEY=

# --- Supabase (free project: Postgres + pgvector + Auth + Storage) ---
# Project settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Project settings -> Database -> Connection string (URI, with pgvector enabled)
DATABASE_URL=

# --- Frontend -> backend wiring ---
# Local dev default; set to the deployed Render URL in production
NEXT_PUBLIC_API_URL=http://localhost:8000
# Public Supabase creds consumed by the Next.js client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional product analytics (PostHog). Empty = analytics disabled (no-op).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Optional market/news data providers ---
# Financial Modeling Prep free tier (250 req/day) — optional; yfinance needs no key
FMP_API_KEY=
# NewsAPI dev tier — optional; GDELT needs no key
NEWSAPI_KEY=

# --- Graph DB (Phase 9 stretch only; MVP uses in-process NetworkX) ---
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# --- Runtime config ---
# Comma-separated tickers ingested by default
FINCOPILOT_TICKERS=AAPL,MSFT,AMZN,TSLA,JPM,NVDA,META,GOOGL,EMAAR.AE,IHC.AE
# Force local embeddings/reranker even when API keys are present (CI/offline)
FINCOPILOT_OFFLINE_MODE=false
LOG_LEVEL=INFO
# Production CORS allow-list (the deployed frontend origin). Empty = allow all (dev).
FRONTEND_ORIGIN=

# --- Ingestion (Phase 1) ---
# SEC EDGAR fair-access requires a descriptive User-Agent with real contact info.
EDGAR_USER_AGENT=FinCopilot research your-email@example.com
# Embedding backend: auto | gemini | local | hash
#   auto  -> gemini if GEMINI_API_KEY set and not offline, else local
#   local -> sentence-transformers bge-small (384d); hash fallback if torch absent
#   hash  -> deterministic hashing embedder (384d) for CI/tests (no torch/network)
FINCOPILOT_EMBED_BACKEND=auto
# Local store / BM25 index / raw docs live here (gitignored)
DATA_DIR=data
